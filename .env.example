# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=pokemon

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL
NEXTAUTH_URL=http://localhost:3000

# Google AdSense (free tier only, catalog routes only)
# Leave both blank to disable ads entirely (no script loaded, no slots rendered).
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=

# pokemontcg.io (https://docs.pokemontcg.io)
POKEMONTCG_API_KEY=
# TCGdex (https://tcgdex.dev) — primary catalog source
TCGDEX_LANG=it
# Seeder source: 'tcgdex' (new) or 'pokemontcg' (legacy fallback)
SEED_SOURCE=tcgdex
